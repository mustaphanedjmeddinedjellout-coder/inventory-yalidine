# Server Environment Variables
PORT=5000
NODE_ENV=production
DB_PATH=./data/inventory.db
UPLOAD_DIR=./uploads

# Storefront integration (Noire -> Inventory Store API)
STORE_API_KEY=replace_with_store_secret
# Comma-separated list of browser origins allowed to call this API.
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-noire-domain.com

# Yalidine Delivery API
YALIDINE_API_ID=your_api_id_here
YALIDINE_API_TOKEN=your_api_token_here
YALIDINE_FROM_WILAYA=Alger
